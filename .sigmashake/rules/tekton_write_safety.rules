# tekton_write_safety.rules
# Technology: tekton | Capability: write

rule tekton-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_tekton_PATTERN"
  MESSAGE "Blocked an unsafe pattern in tekton. Use the recommended best practices for 2025/2026."
}

rule tekton-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_tekton_API"
  MESSAGE "You are using an outdated API for tekton. Please upgrade to the newer API."
}
